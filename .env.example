# NetSuite Account ID (found in your NS URL, e.g. app.netsuite.com shows 1234567)
NS_ACCOUNT_ID=1234567

# Token-Based Authentication credentials
# Setup: NS → Setup → Integration → Manage Integrations → New
NS_CONSUMER_KEY=paste_consumer_key_here
NS_CONSUMER_SECRET=paste_consumer_secret_here

# Setup: NS → Setup → Users/Roles → Access Tokens → New
NS_TOKEN_KEY=paste_token_key_here
NS_TOKEN_SECRET=paste_token_secret_here

# Port (Render sets this automatically — leave as 3000 for local dev)
PORT=3000
